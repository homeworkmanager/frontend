{
  "name": "journal-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint . || eslint . --fix",
    "format": "prettier --write .",
    "test": "vitest",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,css}": [
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --no-error-on-unmatched-pattern --fix"
    ]
  },
  "dependencies": {
    "@reduxjs/toolkit": "2.3.0",
    "axios": "1.13.2",
    "clsx": "2.1.1",
    "formik": "2.4.6",
    "framer-motion": "11.12.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-redux": "9.1.2",
    "react-router-dom": "6.27.0",
    "swiper": "12.0.3",
    "typescript": "5.6.2",
    "yup": "1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "9.13.0",
    "@types/node": "25.0.3",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "5.1.2",
    "css-loader": "7.1.2",
    "eslint": "9.13.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "eslint-plugin-react-refresh": "0.4.14",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "globals": "15.11.0",
    "husky": "9.1.7",
    "lint-staged": "15.3.0",
    "prettier": "3.3.3",
    "style-loader": "4.0.0",
    "typescript": "5.6.2",
    "typescript-eslint": "8.11.0",
    "vite": "7.3.0",
    "vite-plugin-pwa": "1.2.0",
    "vitest": "3.2.4"
  }
}